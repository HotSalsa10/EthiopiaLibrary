rules_version = '2';

// Single-operator library backup: only the library's own signed-in account
// may read or write ANY document. Everyone else - including unauthenticated
// visitors and any other Firebase Auth user - is denied.
//
// BEFORE DEPLOYING: replace OPERATOR_UID below with the real UID of the
// library account (Firebase console -> Authentication -> Users -> copy UID).
//
// Deploy: Firebase console -> Firestore Database -> Rules -> paste -> Publish.
// This file in the repo is the source of truth; keep console and file equal.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == 'OPERATOR_UID';
    }
  }
}
